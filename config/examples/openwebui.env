# OpenWebUI using this Qdrant package as its vector database.
#
# Set these in the OpenWebUI app's environment. OpenWebUI reaches Qdrant over its public REST domain,
# not localhost (Cloudron apps are isolated containers).

VECTOR_DB=qdrant
QDRANT_URI=https://qdrant.example.com
QDRANT_API_KEY=<the admin key, or a scoped JWT>

# For a shared instance, isolate each OpenWebUI knowledge base with multitenancy:
ENABLE_QDRANT_MULTITENANCY_MODE=true

# Note: OpenWebUI can drive Qdrant to high memory use. This package's memory guard (strict mode)
# rejects writes rather than being killed, but for large knowledge bases raise the app's memory limit
# or move vectors on disk. Do not repoint an OpenWebUI that already has a vector store configured
# without a migration plan, because its existing embeddings live in the old store.
